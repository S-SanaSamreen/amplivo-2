PROJECT_NAME="Amplivo ERP Auth Service"
ENVIRONMENT=development

# ---- Database (SQLAlchemy 2.0 async + asyncpg) ----------------------------
# This is the ONLY connection string the backend actually connects with.
#
# Local Postgres:
#   DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/amplivo_erp
#
# Supabase: Project Settings -> Database -> Connection string -> URI, then
# change the "postgresql://" prefix to "postgresql+asyncpg://":
#   DATABASE_URL=postgresql+asyncpg://postgres:<db-password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/amplivo_erp

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE_SECONDS=1800
DB_POOL_TIMEOUT_SECONDS=30
DB_ECHO=false
# "require" for Supabase or any remote Postgres; "disable" for local dev
# against a Postgres instance with no SSL configured.
DB_SSL_MODE=disable
DB_STARTUP_TIMEOUT_SECONDS=5.0

# ---- Supabase project (optional) ------------------------------------------
# Captured for completeness / any future direct use of the Supabase client
# SDK (Storage, Realtime, etc.). NOT read by the SQLAlchemy connection above
# - that only uses DATABASE_URL. Found in Project Settings -> API.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- JWT --------------------------------------------------------------
JWT_SECRET_KEY=change-this-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

BCRYPT_ROUNDS=12

CORS_ORIGINS=["http://localhost:3000"]

# ---- Account lockout (Phase 2) ---------------------------------------
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15

# ---- Rate limiting (Phase 2) ------------------------------------------
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_REGISTER_PER_MINUTE=3
RATE_LIMIT_REFRESH_PER_MINUTE=10

# ---- Email verification / password reset (Phase 3) ---------------------
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# ---- Session management (Phase 4) --------------------------------------
SESSION_INACTIVITY_TIMEOUT_MINUTES=60
